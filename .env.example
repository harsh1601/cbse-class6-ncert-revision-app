NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key for private visitor audit writes.
# Never expose this with a NEXT_PUBLIC_ prefix.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Chat Tutor AI integration.
# Leave blank to use the built-in local Class 6 tutor fallback.
# Use an OpenAI-compatible chat completions endpoint, for example:
# AI_TUTOR_API_URL=https://api.openai.com/v1/chat/completions
AI_TUTOR_API_URL=
AI_TUTOR_API_KEY=
AI_TUTOR_MODEL=
